# ---- Database (Supabase PostgreSQL) ----
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ---- Auth ----
# Generate with:  openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ---- AI provider (fal.ai) ----
# Get at https://fal.ai/dashboard/keys — one key powers generation + file uploads.
FAL_KEY=""

# ---- OAuth providers ----
# Google Cloud Console -> OAuth 2.0 Client ID.
# Authorized redirect: https://YOUR_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional — uncomment the provider blocks in auth.ts before setting.
APPLE_ID=""
APPLE_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# ---- Stripe ----
# When STRIPE_SECRET_KEY is set, /api/stripe/checkout + /api/billing/checkout
# use real Stripe Checkout; without it the UI shows "coming soon" and only
# admin emails can still hit the dev stub.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Webhook secret from `stripe listen` (dev) or the dashboard endpoint (prod).
# Required for /api/billing/webhook to verify Stripe signatures.
STRIPE_WEBHOOK_SECRET=""

# Stripe price ids per plan / topup. Names are STRIPE_PRICE_<ID_UPPER_SNAKE>.
# Plan ids come from lib/credits.ts (PLANS); topup ids from CreditPackage rows.
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_CREATOR=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_STUDIO=""
STRIPE_PRICE_TOPUP_50=""
STRIPE_PRICE_TOPUP_150=""
STRIPE_PRICE_TOPUP_500=""
STRIPE_PRICE_TOPUP_1000=""

# ---- Social OAuth (stub) ----
INSTAGRAM_CLIENT_ID=""
INSTAGRAM_CLIENT_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
X_CLIENT_ID=""
X_CLIENT_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
