# ---- Database (Supabase PostgreSQL) ----
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ---- Auth ----
# Generate with:  openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ---- AI provider (fal.ai) ----
# Get at https://fal.ai/dashboard/keys — one key powers generation + file uploads.
FAL_KEY=""

# ---- OAuth providers ----
# Google Cloud Console -> OAuth 2.0 Client ID.
# Authorized redirect: https://YOUR_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional — uncomment the provider blocks in auth.ts before setting.
APPLE_ID=""
APPLE_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# ---- Stripe ----
# When STRIPE_SECRET_KEY is set, /api/stripe/checkout + /api/billing/checkout
# use real Stripe Checkout; without it the UI shows "coming soon" and only
# admin emails can still hit the dev stub.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Webhook secret from `stripe listen` (dev) or the dashboard endpoint (prod).
# Required for /api/billing/webhook to verify Stripe signatures.
STRIPE_WEBHOOK_SECRET=""

# Stripe price ids per plan / topup. Names are STRIPE_PRICE_<ID_UPPER_SNAKE>.
# Plan ids come from lib/credits.ts (PLANS); topup ids from CreditPackage rows.
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_CREATOR=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_STUDIO=""
STRIPE_PRICE_TOPUP_50=""
STRIPE_PRICE_TOPUP_150=""
STRIPE_PRICE_TOPUP_500=""
STRIPE_PRICE_TOPUP_1000=""

# ---- Persona (soul-id feature) ----
# HS256 secret for signing fal.ai training webhook JWTs.
# Generate with: openssl rand -base64 32
PERSONA_WEBHOOK_SECRET=""
# Set to "true" in non-production to bypass the 24h cooling period gate
# (for E2E tests — never set in production)
TEST_SKIP_COOLING_PERIOD=""
# Set to "true" to mock all fal.ai calls (for E2E tests)
MOCK_FAL=""
# App public URL used to build signed webhook URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Transactional email (Resend) ----
# Get at https://resend.com/api-keys — required in prod. Dev: logs email to console.
RESEND_API_KEY=""
# From address for all transactional emails. Default: onboarding@resend.dev (Resend sandbox).
# In prod, use a verified domain address e.g. noreply@yourdomain.com
RESEND_FROM_EMAIL=""

# ---- Rate limiting (Upstash Redis) ----
# Get at https://console.upstash.com/ → Redis → REST API. Required in prod.
# Dev: falls back to in-memory Map (single-instance, not distributed).
UPSTASH_REDIS_REST_URL=""
# Auth token for the Upstash Redis instance above.
UPSTASH_REDIS_REST_TOKEN=""

# ---- Supabase Storage ----
# Project URL from https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=""
# Service-role key from the same settings page. Server-only — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# ---- Error tracking (optional) ----
# Sentry DSN. When empty, the Sentry SDK is a no-op. Get one at
# https://sentry.io/ — any project tier works.
NEXT_PUBLIC_SENTRY_DSN=""

# ---- Bot challenge (Cloudflare Turnstile) ----
# Free at https://dash.cloudflare.com → Turnstile → Add a site.
# In production, gates /api/auth/register so a botnet can't mass-create
# free-tier accounts to drain the welcome-bonus credit pool. When BOTH
# env vars are empty the widget renders nothing and the server skips
# verification — local dev / preview deploys keep working.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ---- Social OAuth (stub) ----
INSTAGRAM_CLIENT_ID=""
INSTAGRAM_CLIENT_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
X_CLIENT_ID=""
X_CLIENT_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
